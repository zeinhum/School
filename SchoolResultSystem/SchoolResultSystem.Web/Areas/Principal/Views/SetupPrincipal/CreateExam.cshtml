@using System.Security.Cryptography
@model List<SchoolResultSystem.Web.Models.SubjectModel>;
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section Styles {
<link rel="stylesheet" href="~/css/rightnav.css" />
<link rel="stylesheet" href="~/css/cstview.css" />
<link rel="stylesheet" href="~/css/header.css" />
}
<link rel="stylesheet" href="~/css/form.css" />

<script type="module" src="/js/createExam.js"></script>

<partial name="_header" />

<p>@ViewBag.error</p>
<div class="dashboard">
    <div>
        <div class="partial-container"></div>

        <div class="card">
            <p class="error"></p>
            <h2 class="card-head">Create Exam</h2>
            
            <hr />
            <div class="exam-section">
                <button class="select-existing actions btn-success">Select an Exam</button>
                <button class="newexam actions btn-success">Create New Exam</button>
                <div id="select-wraper"></div>
                
                
            </div>
            <hr />
            <!-- Rubric section !-->
            <div class="reubric-section">
                <h3 class="card-head">Set Subject Marking Rubric</h3>
                <div class="non-table">
                    <div class="group">
                        <lebel>Theory Mark</lebel>
                        <input class="" type="text" id="Thmark" required placeholder="Exam Name" />
                    </div>
                    <div class="group">
                        <lebel>Practicl Mark</lebel>
                        <input class="" type="text" id="Prmark" required placeholder="Exam Name" />
                    </div>
                    <div class="group">
                        <lebel>Theory Credit Hour</lebel>
                        <input class="" type="text" id="ThCrh" required placeholder="Exam Name" />
                    </div>
                    <div class="group">
                        <lebel >Practical Credit Hour</lebel>
                        <input class="" type="text" id="PrCrh" required placeholder="Exam Name" />
                    </div>
                </div>
                <button id ="set-all" class="actions btn-success">Select For All Subjects</button>
            </div>
            <hr />

            <table class="form-card">

                <thead>
                    <tr>
                        <th>Subjects</th>
                        <th>Theory Mark</th>
                        <th>Practical Mark</th>
                        <th>Theory Crh</th>
                        <th>Practical Crh</th>
                        <th>Add</th>
                    </tr>
                </thead>

                <tbody class="form-data">
                    <tr>
                        <td>
                            <select id = "Scode" class="Scode" name="SCode" required>
                                <option value="" disabled selected>Select Subject</option>
                                @foreach (var sc in Model)
                                {
                                    <option value=@sc.SCode>@sc.SCode - @sc.SName</option>
                                }
                            </select>
                        </td>
                        <td><input type="number" name="ThMark" required size="2" /></td>
                        <td><input type="number" name="PrMark" required size="2" /></td>
                        <td><input type="number" name="ThCrh" required size="2" /></td>
                        <td><input type="number" name="PrCrh" required size="2" /></td>

                    </tr>
                </tbody>
            </table>
            <hr />
            <button id="create-rubrik" class="actions btn-success">Set Rubrick</button>
        </div>
    </div>
    <partial name="_RightNavBar" model="-1" />
</div>