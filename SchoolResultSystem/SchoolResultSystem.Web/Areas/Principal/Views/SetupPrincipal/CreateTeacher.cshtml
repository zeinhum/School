<div>

    <div class="welcome">
        <h2>Create teacher account</h2>
        @if (!string.IsNullOrEmpty(ViewBag.success))
        {
            <p>@ViewBag.success</p>
        }
        @if (!string.IsNullOrEmpty(ViewBag.error))
        {
            <p class="error">@ViewBag.error</p>
        }
    </div>

    <div class="card">
        <form method="post" action="/Principal/SetupPrincipal/SaveTeacher" class="form-card">
            <div class="form-group">
                <label for="UserId">Teacher's Unique ID*</label>
                <input type="text" id="UserId" name="UserId" placeholder="e.g. T01" required />
            </div>
            <div class="form-group">
                <label for="UserName">Teacher's Name*</label>
                <input type="text" id="FullName" name="FullName" placeholder="Teacher's name" required />
            </div>
            <div class="form-group">
                <label for="Username">Username*</label>
                <input type="text" id="Username" name="UserName" placeholder="Teacher's Username" required />
            </div>

            <div class="form-group">
                <label for="Password">Password*</label>
                <input type="password" id="Password" name="Password" placeholder="Passwords" required />
            </div>

            <input type="hidden" name="Role" value="Teacher" />

            <button type="submit" class="btn-primary">Create Account</button>
        </form>
    </div>
</div>
