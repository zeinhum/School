

<h2 class="title">Setup academic calendar for current year.</h2>
<p class="subtitle">
    Record the days when school will be off. Rest of the days will be marked as working days.
</p>
<div class="card">
    <div class="form-card">
        <!-- Weekend section -->
        <p>Select weekdays of any one week of the year.</p>
        <table class="weekend">
            <thead>
                <tr>
                    <th>Weekend Days</th>
                    <th>Row</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><input type="date" /></td>
                    <td>
                        <button type="button" class="btn-add" data-action="addRow">+</button>
                        <button type="button" class="btn-remove" data-action="removeRow">-</button>
                    </td>
                </tr>
            </tbody>
        </table>

        <hr />
        <h3>Other Leaves</h3>
        <table class="leave-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Description</th>
                    <th>Add/Remove</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><input type="date" /></td>
                    <td><input type="text" placeholder="Reason" /></td>
                    <td>
                        <button type="button" class="btn-add" data-action="addRow">+</button>
                        <button type="button" class="btn-remove" data-action="removeRow">-</button>
                    </td>
                </tr>
            </tbody>
        </table>
        <button class="btn-primary" data-action="setCallendar">Set Calendar</button>

        <button class="btn-delete" data-action="reset">Clean callendar</button>
    </div>
</div>